NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/attendance

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rotation support — set to previous secret during key rotation
JWT_ACCESS_SECRET_PREVIOUS=
JWT_REFRESH_SECRET_PREVIOUS=

# App
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
